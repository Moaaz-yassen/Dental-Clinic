@model Dental_Clinic.Models.TreatmentCase
@{
    ViewData["Title"] = "تعديل الحالة";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm rounded-4" style="max-width:750px">
    <div class="card-body p-4">
        <form asp-action="EditCase" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">عنوان الحالة</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">الوصف التفصيلي</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">صورة قبل (اتركها فارغة للإبقاء على الحالية)</label>
                    @if (!string.IsNullOrEmpty(Model.BeforeImagePath))
                    {
                        <img src="@Model.BeforeImagePath" class="img-fluid rounded-3 mb-2 d-block" style="max-height:150px" 
                             onerror="this.remove()" alt="قبل">
                    }
                    <input type="file" name="beforeImage" class="form-control" accept="image/*"
                           onchange="previewImage(this,'bp')">
                    <img id="bp" class="img-fluid rounded-3 mt-2 d-none" style="max-height:180px">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">صورة بعد (اتركها فارغة للإبقاء على الحالية)</label>
                    @if (!string.IsNullOrEmpty(Model.AfterImagePath))
                    {
                        <img src="@Model.AfterImagePath" class="img-fluid rounded-3 mb-2 d-block" style="max-height:150px"
                             onerror="this.remove()" alt="بعد">
                    }
                    <input type="file" name="afterImage" class="form-control" accept="image/*"
                           onchange="previewImage(this,'ap')">
                    <img id="ap" class="img-fluid rounded-3 mt-2 d-none" style="max-height:180px">
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">
                    <i class="fa-solid fa-save me-2"></i> حفظ التعديلات
                </button>
                <a asp-action="Cases" class="btn btn-outline-secondary rounded-pill px-4">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(input, id) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    const el = document.getElementById(id);
                    el.src = e.target.result;
                    el.classList.remove('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
